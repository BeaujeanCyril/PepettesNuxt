generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["pepettes"]
}

model Family {
  id              Int           @id @default(autoincrement())
  keycloakUserId  String?       @unique  // Keycloak sub (UUID)
  code            String?       @unique  // Legacy, kept for backward compat
  name            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  months          BudgetMonth[]
  categories      Category[]
  recurringLines  RecurringLine[]

  @@schema("pepettes")
}

model BudgetMonth {
  id             Int          @id @default(autoincrement())
  year           Int
  month          Int
  manualBalance  Float?       // Override du solde cumule (null = calcul auto)
  manualReport   Float?       // Override du report precedent (null = calcul auto)
  manualSolde    Float?       // Override du solde du mois (null = calcul auto)
  familyId       Int
  family         Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  lines          BudgetLine[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([year, month, familyId])
  @@schema("pepettes")
}

model BudgetLine {
  id            Int         @id @default(autoincrement())
  name          String
  amount        Float
  isIncome      Boolean     @default(false)
  paymentMethod String?     // "visa", "domiciliation", "ordre_permanent", "virement", null
  isPaid        Boolean     @default(false)
  dayOfMonth    Int?        // jour habituel de paiement (1-31)
  categoryId    Int?
  category      Category?   @relation(fields: [categoryId], references: [id])
  budgetMonthId Int
  budgetMonth   BudgetMonth @relation(fields: [budgetMonthId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@schema("pepettes")
}

model Category {
  id              Int              @id @default(autoincrement())
  name            String
  emoji           String           @default("📁")
  familyId        Int
  family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  lines           BudgetLine[]
  recurringLines  RecurringLine[]

  @@unique([name, familyId])
  @@schema("pepettes")
}

model RecurringLine {
  id            Int       @id @default(autoincrement())
  name          String
  amount        Float
  isIncome      Boolean   @default(false)
  type          String    @default("monthly")
  paymentMethod String?   // "visa", "domiciliation", "ordre_permanent", "virement", null
  dayOfMonth    Int?      // jour habituel de paiement (1-31)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  familyId   Int
  family     Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  startMonth Int       // 1-12
  startYear  Int
  endMonth   Int?      // null = ongoing
  endYear    Int?      // null = ongoing
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@schema("pepettes")
}
